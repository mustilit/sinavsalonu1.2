{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./e2e-out",
    "types": ["node"]
  },
  "include": ["e2e/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
