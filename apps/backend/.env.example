# ─────────────────────────────────────────────────────────────────────────
#  Sınav Salonu — Backend env örnek dosyası
#
#  Kullanım:
#    cp apps/backend/.env.example apps/backend/.env
#    (sonra DATABASE_URL ve JWT_SECRET'ı kendi değerlerinle güncelle)
#
#  Doğrulama: src/config/env.ts (Zod ile boot-time validasyon)
#  Production'da zorunlular: DATABASE_URL, JWT_SECRET (≥ 32 karakter, default
#  değer DEĞİL), CLIENT_URL, REDIS_URL.
# ─────────────────────────────────────────────────────────────────────────

# ── Çekirdek ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Reverse proxy (nginx, ALB) arkasında çalışıyorsa Express'in X-Forwarded-* header'ına güvenmesini sağlar.
# Production'da '1' otomatik set edilir.
TRUST_PROXY=

# Multi-tenant default tenant ID (seed & lokal geliştirme için)
DEFAULT_TENANT_ID=dev-tenant

# Frontend URL'i (parola sıfırlama linki vs. için)
FRONTEND_URL=http://localhost:5173

# CORS — production'da ZORUNLU. Birden fazla origin için virgülle ayır.
CLIENT_URL=http://localhost:5173

# Backend public URL (upload edilen dosyalar için absolute URL üretimi)
BACKEND_URL=http://localhost:3000

# ── Google OAuth (Sign-in with Google) ───────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Aynı Client ID hem frontend (VITE_GOOGLE_CLIENT_ID) hem backend tarafında kullanılır.
# Boş bırakıldığında /auth/google endpoint'i 500 döner — Google ile giriş özelliği devre dışı kalır.
GOOGLE_CLIENT_ID=

# ── Veritabanı (PostgreSQL + Prisma) ─────────────────────────────────────
# Local geliştirme (host üzerinde):
#   postgresql://postgres:postgres@localhost:5432/sinavsalonu_v2?schema=public
# Docker compose (container içinde):
#   postgresql://postgres:postgres@postgres:5432/sinavsalonu_v2?schema=public
# PgBouncer ile prod:
#   postgresql://USER:PASS@pgbouncer:6432/sinavsalonu?schema=public&pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sinavsalonu_v2?schema=public

# Docker compose içinden çalışıyorsa '1' set et (host normalize)
DOCKER=

# ── Redis (Cache + BullMQ + Throttler storage) ───────────────────────────
# Boş bırakılırsa local geliştirmede tamamen devre dışı kalabilir.
# Production'da ZORUNLU.
REDIS_URL=redis://localhost:6379

# REDIS_URL yoksa fallback için ayrı host/port (opsiyonel)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# '1' set edilirse Redis tamamen atlanır (cache, queue, throttler kapanır).
# Production'da '1' olamaz (env.ts fail-fast).
REDIS_DISABLED=

# ── JWT (Auth) ───────────────────────────────────────────────────────────
# Production'da en az 32 karakter ve default değer DEĞİL.
# Üretme: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production

# Saniye cinsinden. 604800 = 7 gün.
JWT_EXPIRES_IN=604800

# ── Rate Limit & Bruteforce Koruma ───────────────────────────────────────
# '1' ise tüm rate limiter devre dışı (test için).
THROTTLE_DISABLED=
THROTTLE_TTL_SECONDS=60

# Login bruteforce sayaçları (IP + email bazlı)
LOGIN_IP_LIMIT=20
LOGIN_IP_TTL_SECONDS=60
LOGIN_EMAIL_LIMIT=10
LOGIN_EMAIL_TTL_SECONDS=60
LOGIN_CAPTCHA_AFTER_IP=10
LOGIN_CAPTCHA_AFTER_EMAIL=5

# ── CAPTCHA (hCaptcha / reCAPTCHA / none) ────────────────────────────────
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET_KEY=

# ── Cron / Background Jobs ───────────────────────────────────────────────
# '1' ise tüm scheduled task'lar atlanır (test/CI için).
CRON_DISABLED=

# Email worker port (BullMQ)
WORKER_PORT=3010

# ── Content Security Policy ──────────────────────────────────────────────
# false → CSP başlığı eklenmez. 'true' veya boş → enforce / report-only.
CSP_ENABLED=true

# 'true' → Content-Security-Policy-Report-Only (production'a geçişten önce gözlem)
CSP_REPORT_ONLY=true

# CSP source listeleri (virgülle ayrılmış). 'self' otomatik eklenir.
CSP_CONNECT_SRC=
CSP_SCRIPT_SRC=
CSP_IMG_SRC=
CSP_MEDIA_SRC=
CSP_STYLE_SRC=

# Violation report endpoint
CSP_REPORT_ENDPOINT=/csp-report

# ── Sentry (opsiyonel) ───────────────────────────────────────────────────
# DSN boş bırakılırsa hata izleme devre dışı.
SENTRY_DSN=

# ── Swagger ──────────────────────────────────────────────────────────────
# Dev ortamda '1' ise /docs aktif.
SWAGGER_ENABLED=1

# ── Slack (DLQ alarmı, CI notification) ──────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Ödeme provider (gelecek — webhook signing için secret) ───────────────
# Iyzico
IYZICO_API_KEY=
IYZICO_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── S3 / Object storage (gelecek — file upload) ─────────────────────────
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=sinavsalonu-uploads

# ── Read Replica (opsiyonel) ─────────────────────────────────────────────
# Boş bırakılırsa primary kullanılır.
# DATABASE_REPLICA_URL=postgresql://reader:pass@replica-host:5432/sinavsalonu_v2?schema=public

# ── FX Rate Service ──────────────────────────────────────────────────────
# Provider seçimi: 'fixed' (dev/test) veya 'tcmb' (prod)
FX_PROVIDER=fixed

# FixedFxService kurları — gerçek üretimde TcmbFxService kullanılır
# FX_RATE_TRY_USD=0.031
# FX_RATE_USD_TRY=32.25
# (diğer çiftler için: src/infrastructure/services/FixedFxService.ts'ye bak)

# ── Email Trafiği Modülü ────────────────────────────────────────────────
# AES-256-GCM key — sağlayıcı secret'larını (API key/SMTP şifre) şifrelemek için.
# 64 hex karakter (32 byte) zorunlu. Üret: `openssl rand -hex 32`
EMAIL_SECRETS_KEY=

# BullMQ kuyruk prefix'i (3 ayrı kuyruk: email-critical / email-notify / email-bulk)
EMAIL_REDIS_QUEUE_PREFIX=email

# Şablon dizini — dosya tabanlı Handlebars template'ler
EMAIL_TEMPLATE_DIR=src/infrastructure/email/templates

# Varsayılan from (sağlayıcıda override edilebilir — admin panelinden yönetilir)
EMAIL_DEFAULT_FROM=noreply@sinavsalonu.com
EMAIL_DEFAULT_FROM_NAME=Sınav Salonu

# Email traffic worker health endpoint portu
EMAIL_TRAFFIC_WORKER_PORT=3011
